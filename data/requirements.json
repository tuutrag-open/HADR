    "chunk": "# Level\nLevel 5\n\n## ID\nL5.GEN.9\n\n### Requirement\nApplications shall meet Section 508 compliance guidelines",
    "requirement": "L5.GEN.9"
  },
  {
    "uuid": "45d62826-60c9-489c-bba9-683955add957.1",
    "chunk": "# Level\nLevel 3\n\n## ID\n2.9.2\n\n### Requirement\nPDS will ensure that online interfaces comply with required NASA Guidelines",
    "requirement": "2.9.2"
  },
  {
    "uuid": "c184bdcc-3b89-408c-965c-65ca274fb1c8.1",
    "chunk": "# Level\nLevel 4\n\n## ID\nL4.GEN.5\n\n### Requirement\nThe system shall adhere to NASA-specified guidelines",
    "requirement": "L4.GEN.5"
  },
  {
    "uuid": "f5df8e6e-64a9-49b6-af1f-366920132964.1",
    "chunk": "# Level\nLevel 5\n\n## ID\nL5.GEN.9\n\n### Requirement\nApplications shall meet Section 508 compliance guidelines.",
    "requirement": "L5.GEN.9"
  },
  {
    "uuid": "0b21a800-6314-4735-a7a5-396c38fdc30e.1",
    "chunk": "# Level\nLevel 5\n\n## ID\nL5.SCH.3\n\n### Requirement\nThe service's browser-based user interface shall be Section 508 compliant and adhere to WCAG level A (or better) standards for accessibility.",
    "requirement": "L5.SCH.3"
  },
  {
    "uuid": "fd8bafd1-656c-46dd-adbd-7ec0974f49f6.1",
    "chunk": "# Level\nLevel 3\n\n## ID\n2.9.3\n\n### Requirement\nPDS will meet U.S. federal regulations for the preservation and management of data",
    "requirement": "2.9.3"
  },
  {
    "uuid": "2781fb0c-b6ef-4ac1-b915-afb910cb6220.1",
    "chunk": "# Level\nLevel 4\n\n## ID\nL4.GEN.6\n\n### Requirement\nThe system shall secure Personally Identifiable Information (PII).",
    "requirement": "L4.GEN.6"
  },
  {
    "uuid": "44b978c7-3054-468b-b006-a61acb7ff3c8.1",
    "chunk": "# Level\nLevel 5\n\n## ID\nL5.RPT.3\n\n### Requirement\nThe service shall utilize a secure transfer protocol for transferring log files across the Internet.",
    "requirement": "L5.RPT.3"
  },
  {
    "uuid": "5a5d6c5e-185f-47fa-9f56-b2c2ef286d6e.1",
    "chunk": "# Level\nLevel 5\n\n## ID\nL5.RPT.7\n\n### Requirement\nThe service shall control access to the user interface and metrics repository.",
    "requirement": "L5.RPT.7"
  },
